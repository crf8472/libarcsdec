## Base configuration for doxygen.
##
## Can be used as a standalone config for doxygen or to be included by another
## doxyfile that adds generator-specific configuration.
## See e.g. doc/thirdparty/mcss/Doxyfile.in.

## Project information
PROJECT_NAME           = "@PROJECT_NAME@"
PROJECT_NUMBER         = "@PROJECT_VERSION_STRING@"
PROJECT_BRIEF          = "@PROJECT_BRIEF_DESC@"

## Which parts to show
INTERNAL_DOCS          = @DOXYGEN_INTERNAL_DOCS@
EXTRACT_LOCAL_CLASSES  = NO
HIDE_UNDOC_MEMBERS     = YES
HIDE_UNDOC_CLASSES     = YES
HIDE_FRIEND_COMPOUNDS  = YES
HIDE_IN_BODY_DOCS      = YES
VERBATIM_HEADERS       = NO
ENABLED_SECTIONS       = @DOXYGEN_ENABLED_SECTIONS@
#HIDE_INLINE_NAMESPACES = YES   ## https://github.com/doxygen/doxygen/pull/10070

## Grouping
INLINE_GROUPED_CLASSES = YES
SHOW_GROUPED_MEMB_INC  = YES
GROUP_GRAPHS           = NO

## Sorting
SORT_BRIEF_DOCS        = YES
SORT_MEMBERS_CTORS_1ST = YES
SORT_GROUP_NAMES       = YES

## Text Replacements
##
## Define every m.css markup macro empty to effectively ignore m.css markup
## in doxygen comments. This Doxyfile can therefore be used without using m.css.
## An m.css specific Doxyfile may include this file and overwrite these ALIASES.
ALIASES               += \
							"m_div{1}="                  \
							"m_enddiv="                  \
							"m_span{1}="                 \
							"m_endspan="                 \
							"m_class{1}="                \
							"m_footernavigation="        \
							"m_examplenavigation{2}="    \
							"m_keywords{1}="             \
							"m_keyword{3}="              \
							"m_enum_values_as_keywords="

## Path Modification
STRIP_FROM_PATH        = @DOXYGEN_STRIP_FROM_PATH@
STRIP_FROM_INC_PATH    = @DOXYGEN_STRIP_FROM_INC_PATH@

## Input
USE_MDFILE_AS_MAINPAGE = @DOXYGEN_USE_MDFILE_AS_MAINPAGE@
MARKDOWN_ID_STYLE      = GITHUB
INPUT                  = @DOXYGEN_INPUT@
FILE_PATTERNS          = @DOXYGEN_FILE_PATTERNS@
EXCLUDE_PATTERNS       = *.cpp
RECURSIVE              = YES

## Logging
WARN_LOGFILE           = @PROJECT_LOG_DIR@/Doxygen_Warnings.log
WARN_NO_PARAMDOC       = YES

## Output
OUTPUT_DIRECTORY       = "@DOXYGEN_OUTPUT_DIRECTORY@"
GENERATE_LATEX         = NO


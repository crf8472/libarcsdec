## Doxygen file for generating a manual by lualatex

## Include the base Doxyfile
@INCLUDE = @DOC_DOXYFILE_BASE@

## LaTeX specific

## Processor
LATEX_CMD_NAME         = lualatex

## Style
COMPACT_LATEX          = YES


## Override the following values from included Doxyfile

## Input
INPUT                  = @DOXYGEN_INPUT@              # lualatex/CMakeListst.txt

## Output
##
OUTPUT_DIRECTORY       = "@DOXYGEN_OUTPUT_DIRECTORY@" # lualatex/CMakeListst.txt
LATEX_OUTPUT           = lualatex
GENERATE_LATEX         = YES ## restore default, overwrite Doxyfile-base
GENERATE_HTML          = NO


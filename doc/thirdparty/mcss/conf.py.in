## Configuration options for m.css
##
## See: https://mcss.mosra.cz/documentation/doxygen/

DOXYFILE = 'Doxyfile'

MAIN_PROJECT_URL = "@PROJECT_URL@/"

LINKS_NAVBAR1    = [
    (None, 'modules', []),
    (None, 'pages',   [])
]

LINKS_NAVBAR2    = [
    (None, 'namespaces', []),
    (None, 'annotated',  []),
    (None, 'files',      []),
]

## Expand version namespace and show class list
CLASS_INDEX_EXPAND_LEVELS = 2

## custom, not m.css
my_CUSTOM_STYLESHEET = '@MCSS_CUSTOM_STYLESHEET@'

## Reset m.css stylesheets option only if a stylesheet was explicitly defined
if not my_CUSTOM_STYLESHEET=='':
    STYLESHEETS = [
        'https://fonts.googleapis.com/css?family=Source+Sans+Pro:400,400i,600,600i%7CSource+Code+Pro:400,400i,600',
        my_CUSTOM_STYLESHEET
    ]

## Place m.math.cache in the same directory as the HTML output
M_MATH_CACHE_FILE = 'html/m.math.cache'

